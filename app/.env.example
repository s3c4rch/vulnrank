APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=ml-service-app
APP_ENV=development
DB_HOST=database
DB_PORT=5432
DB_NAME=ml_service
DB_USER=ml_user
DB_PASSWORD=ml_password
DB_ECHO=false
DB_INIT_ATTEMPTS=30
DB_INIT_DELAY=1
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=ml_queue_user
RABBITMQ_PASSWORD=ml_queue_password
RABBITMQ_QUEUE=ml_tasks
RABBITMQ_CONNECTION_ATTEMPTS=30
RABBITMQ_CONNECTION_DELAY=1
RABBITMQ_HEARTBEAT=0
ML_RUNTIME_URL=http://ml-runtime:11434
ML_RUNTIME_TIMEOUT=60
ML_RUNTIME_PULL_TIMEOUT=1800
ML_RUNTIME_TEMPERATURE=0.1
ML_RUNTIME_CONTEXT_LENGTH=4096
ML_RUNTIME_KEEP_ALIVE=5m
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=90
OPENAI_DEFAULT_MODEL=gpt-5.4-mini
