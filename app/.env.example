APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=ml-service-app
APP_ENV=development
DB_HOST=database
DB_PORT=5432
DB_NAME=ml_service
DB_USER=ml_user
DB_PASSWORD=ml_password
DB_ECHO=false
DB_INIT_ATTEMPTS=30
DB_INIT_DELAY=1
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=ml_queue_user
RABBITMQ_PASSWORD=ml_queue_password
RABBITMQ_QUEUE=ml_tasks
RABBITMQ_CONNECTION_ATTEMPTS=30
RABBITMQ_CONNECTION_DELAY=1
